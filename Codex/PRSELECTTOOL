# IDENTICAL MESH DETECTION
# =============================================================================
PR_IDENTICAL_EPSILON = 1e-6


def pr_get_mesh_hash(mesh_transform, ignore_scale=False):
    try:
        shapes = cmds.listRelatives(mesh_transform, shapes=True, type="mesh", fullPath=True) or []
        if not shapes:
            return None

        vtx_count  = cmds.polyEvaluate(mesh_transform, vertex=True)
        edge_count = cmds.polyEvaluate(mesh_transform, edge=True)
        face_count = cmds.polyEvaluate(mesh_transform, face=True)
        area       = cmds.polyEvaluate(mesh_transform, worldArea=True)

        bbox   = cmds.exactWorldBoundingBox(mesh_transform)
        volume = (bbox[3]-bbox[0]) * (bbox[4]-bbox[1]) * (bbox[5]-bbox[2])

        if ignore_scale and vtx_count > 0:
            area   = area   / (vtx_count ** 0.5)        if area   != 0 else 0
            volume = volume / (vtx_count ** (2.0/3.0))  if volume != 0 else 0

        return (int(vtx_count), int(edge_count), int(face_count), float(area), float(volume))
    except Exception:
        return None


def pr_compare_mesh_topology(mesh1, mesh2, ignore_scale=False):
    h1 = pr_get_mesh_hash(mesh1, ignore_scale=ignore_scale)
    h2 = pr_get_mesh_hash(mesh2, ignore_scale=ignore_scale)
    if not h1 or not h2:
        return False
    return h1[0] == h2[0] and h1[1] == h2[1] and h1[2] == h2[2]


def pr_compare_mesh_geometry(mesh1, mesh2, tolerance=0.01, ignore_scale=False):
    h1 = pr_get_mesh_hash(mesh1, ignore_scale=ignore_scale)
    h2 = pr_get_mesh_hash(mesh2, ignore_scale=ignore_scale)
    if not h1 or not h2:
        return False
    if h1[0] != h2[0] or h1[1] != h2[1] or h1[2] != h2[2]:
        return False
    area1, area2 = abs(h1[3]), abs(h2[3])
    if area1 > PR_IDENTICAL_EPSILON:
        if abs(area1 - area2) / area1 > tolerance:
            return False
    vol1, vol2 = abs(h1[4]), abs(h2[4])
    if vol1 > PR_IDENTICAL_EPSILON:
        if abs(vol1 - vol2) / vol1 > tolerance:
            return False
    return True


def pr_compare_mesh_exact(mesh1, mesh2, pos_tolerance=0.001, ignore_scale=False):
    if not pr_compare_mesh_topology(mesh1, mesh2, ignore_scale=ignore_scale):
        return False
    try:
        vtx1 = cmds.xform("{0}.vtx[*]".format(mesh1), q=True, ws=True, t=True)
        vtx2 = cmds.xform("{0}.vtx[*]".format(mesh2), q=True, ws=True, t=True)
        if len(vtx1) != len(vtx2):
            return False
        if ignore_scale:
            bbox1  = cmds.exactWorldBoundingBox(mesh1)
            bbox2  = cmds.exactWorldBoundingBox(mesh2)
            size1  = max(bbox1[3]-bbox1[0], bbox1[4]-bbox1[1], bbox1[5]-bbox1[2])
            size2  = max(bbox2[3]-bbox2[0], bbox2[4]-bbox2[1], bbox2[5]-bbox2[2])
            if size1 < PR_IDENTICAL_EPSILON or size2 < PR_IDENTICAL_EPSILON:
                return False
            center1 = [(bbox1[i]+bbox1[i+3])/2.0 for i in range(3)]
            center2 = [(bbox2[i]+bbox2[i+3])/2.0 for i in range(3)]
            for i in range(0, len(vtx1), 3):
                n1   = [(vtx1[i+j]-center1[j])/size1 for j in range(3)]
                n2   = [(vtx2[i+j]-center2[j])/size2 for j in range(3)]
                dist = math.sqrt(sum((n1[j]-n2[j])**2 for j in range(3)))
                if dist > pos_tolerance:
                    return False
        else:
            for i in range(0, len(vtx1), 3):
                dist = math.sqrt(
                    (vtx1[i]-vtx2[i])**2 +
                    (vtx1[i+1]-vtx2[i+1])**2 +
                    (vtx1[i+2]-vtx2[i+2])**2
                )
                if dist > pos_tolerance:
                    return False
        return True
    except Exception:
        return False


def pr_get_mesh_material(mesh_transform):
    try:
        shapes = cmds.listRelatives(mesh_transform, shapes=True, type="mesh", fullPath=True) or []
        if not shapes:
            return None
        sgs    = cmds.listConnections(shapes[0], type="shadingEngine") or []
        if not sgs:
            return None
        shader = cmds.listConnections("{0}.surfaceShader".format(sgs[0]), source=True) or []
        return shader[0] if shader else None
    except Exception:
        return None


def pr_find_identical_meshes(method="geometry", tolerance=0.01, source_mesh=None,
                             ignore_scale=True, filter_by_material=False, select_result=True):
    cmds.undoInfo(openChunk=True)
    try:
        if source_mesh and cmds.objExists(source_mesh):
            source = source_mesh
        else:
            sel = cmds.ls(selection=True, type="transform", long=True) or []
            if not sel:
                cmds.warning("[PR] Select a source mesh first.")
                return []
            source = sel[0]

        if not cmds.listRelatives(source, shapes=True, type="mesh"):
            cmds.warning("[PR] Selected object is not a mesh.")
            return []

        source_material = None
        if filter_by_material:
            source_material = pr_get_mesh_material(source)
            if not source_material:
                filter_by_material = False

        all_transforms = cmds.ls(type="transform", long=True) or []
        mesh_transforms = []
        for t in all_transforms:
            if cmds.listRelatives(t, shapes=True, type="mesh"):
                if filter_by_material:
                    if pr_get_mesh_material(t) == source_material:
                        mesh_transforms.append(t)
                else:
                    mesh_transforms.append(t)

        if not mesh_transforms:
            cmds.warning("[PR] No meshes found in scene.")
            return []

        matches = [source]

        cmds.progressWindow(
            title="Find Identical Meshes",
            progress=0,
            status="Scanning...",
            isInterruptable=True,
            maxValue=len(mesh_transforms)
        )

        for i, mesh in enumerate(mesh_transforms):
            if cmds.progressWindow(query=True, isCancelled=True):
                break
            cmds.progressWindow(edit=True, progress=i+1,
                                status="{0}/{1}".format(i+1, len(mesh_transforms)))
            if mesh == source:
                continue
            is_match = False
            if method == "topology":
                is_match = pr_compare_mesh_topology(source, mesh, ignore_scale=ignore_scale)
            elif method == "geometry":
                is_match = pr_compare_mesh_geometry(source, mesh, tolerance=tolerance, ignore_scale=ignore_scale)
            elif method == "exact":
                is_match = pr_compare_mesh_exact(source, mesh, pos_tolerance=tolerance, ignore_scale=ignore_scale)
            if is_match:
                matches.append(mesh)

        try:
            cmds.progressWindow(endProgress=True)
        except Exception:
            pass

        if len(matches) > 1:
            if select_result:
                cmds.select(matches, r=True)
            return matches

        cmds.warning("[PR] No identical meshes found.")
        return []

    finally:
        try:
            cmds.progressWindow(endProgress=True)
        except Exception:
            pass
        cmds.undoInfo(closeChunk=True)


