# SELECT INNER FACES
# =============================================================================
class PR_SelectInnerFaces:
    @staticmethod
    def _get_edge_loops_from_selection(edges):
        if not edges:
            return []
        edges_flat      = cmds.ls(edges, fl=True)
        edges_remaining = set(edges_flat)
        loops           = []
        while edges_remaining:
            start_edge   = next(iter(edges_remaining))
            current_loop = set([start_edge])
            to_process   = [start_edge]
            while to_process:
                edge  = to_process.pop()
                verts = cmds.polyListComponentConversion(edge, fromEdge=True, toVertex=True)
                verts = cmds.ls(verts, fl=True) or []
                for vert in verts:
                    connected_edges = cmds.polyListComponentConversion(vert, fromVertex=True, toEdge=True)
                    connected_edges = cmds.ls(connected_edges, fl=True) or []
                    for ce in connected_edges:
                        if ce in edges_remaining and ce not in current_loop:
                            current_loop.add(ce)
                            to_process.append(ce)
            loops.append(list(current_loop))
            edges_remaining -= current_loop
        return loops

    @classmethod
    def run(cls):
        selected_edges = cmds.filterExpand(sm=32) or []
        if not selected_edges:
            cmds.warning("[PR] Select one or two edge loop(s).")
            return 0

        cmds.undoInfo(openChunk=True, infinity=True)
        try:
            all_edges = cmds.ls(sl=True, fl=True) or []
            sel_obj   = cmds.ls(sl=True, fl=True, o=True) or []
            if not sel_obj:
                cmds.warning("[PR] Cannot determine object.")
                return 0

            loops     = cls._get_edge_loops_from_selection(all_edges)
            num_loops = len(loops)

            if num_loops == 0:
                cmds.warning("[PR] No edge loop detected.")
                return 0
            elif num_loops > 2:
                cmds.warning("[PR] {} edge loops detected. Maximum 2 supported.".format(num_loops))
                return 0

            cmds.select(all_edges, r=True)
            cmds.ConvertSelectionToFaces()
            adjacent_faces = cmds.ls(sl=True, fl=True) or []
            if not adjacent_faces:
                cmds.warning("[PR] Cannot convert to faces.")
                return 0

            cmds.polyProjection(
                sel_obj[0], ch=1, type="Planar", ibd=False, cm=True,
                uvSetName="PRSelect_EdgeLoop_UV", kir=True, md="c"
            )
            cmds.polyUVSet(cuv=True, uvSet="PRSelect_EdgeLoop_UV")
            cmds.select(all_edges, r=True)
            cmds.polyMapCut()

            if num_loops == 1:
                cmds.select(adjacent_faces[0], r=True)
                cmds.SelectMeshUVShell()
            else:
                cmds.select(loops[0], r=True)
                cmds.ConvertSelectionToFaces()
                faces_loop1 = set(cmds.ls(sl=True, fl=True) or [])
                cmds.select(loops[1], r=True)
                cmds.ConvertSelectionToFaces()
                faces_loop2  = set(cmds.ls(sl=True, fl=True) or [])
                common_faces = faces_loop1 & faces_loop2
                if common_faces:
                    cmds.select(list(common_faces)[0], r=True)
                    cmds.SelectMeshUVShell()
                else:
                    cmds.select(list(faces_loop1)[0], r=True)
                    cmds.SelectMeshUVShell()

            inner_faces = cmds.ls(sl=True, fl=True) or []
            inner_faces = [f for f in inner_faces if ".f[" in f]

            try:
                cmds.polyUVSet(d=True, uvSet="PRSelect_EdgeLoop_UV")
            except Exception:
                pass

            if inner_faces:
                cmds.select(inner_faces, r=True)
                pr_force_selection_faces_only()

            return len(cmds.ls(sl=True, fl=True) or [])

        except Exception as e:
            cmds.warning("[PR] Inner faces selection failed: {}".format(e))
            return 0
        finally:
            cmds.undoInfo(closeChunk=True)


