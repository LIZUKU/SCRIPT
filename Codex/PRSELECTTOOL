class PR_ColorBtn(QtWidgets.QPushButton):
    def __init__(self, text="", tip="", bg="#2d2d2d", fg="#a0a0a0", w=32, h=26, parent=None):
        super(PR_ColorBtn, self).__init__(text, parent)
        self.setFixedSize(w, h)
        self.setToolTip(tip)
        self._bg      = bg
        self._fg      = fg
        self._base_bg = bg
        self._base_fg = fg
        self._update()

    def _update(self):
        self.setStyleSheet("""
            QPushButton {{
                background-color: {bg}; color: {fg};
                border: 1px solid #222; border-radius: 3px;
                font-weight: bold; font-size: 10px;
            }}
            QPushButton:hover {{ background-color: {bgh}; border-color: #444; }}
            QPushButton:pressed {{ background-color: #1a1a1a; }}
        """.format(bg=self._bg, fg=self._fg,
                   bgh=QtGui.QColor(self._bg).lighter(125).name()))

    def set_active(self, active):
        self._bg = "#3a4a3a" if active else self._base_bg
        self._fg = "#a0ffa0" if active else self._base_fg
        self._update()

    def set_has_data(self, has_data):
        if has_data:
            self._bg = "#2d3d2d"
            self._fg = "#80c080"
        else:
            self._bg = self._base_bg
            self._fg = "#505050"
        self._update()


class PR_Toast(QtWidgets.QLabel):
    def __init__(self, parent=None):
        super(PR_Toast, self).__init__(parent)
        self.setAlignment(QtCore.Qt.AlignCenter)
        self.setStyleSheet("""
            background-color: #3a5a3a; color: #c0ffc0;
            border-radius: 4px; padding: 6px 12px;
            font-size: 10px; font-weight: bold;
        """)
        self.setWindowFlags(QtCore.Qt.ToolTip | QtCore.Qt.FramelessWindowHint)
        self._timer = QtCore.QTimer()
        self._timer.setSingleShot(True)
        self._timer.timeout.connect(self.hide)

    def show_msg(self, text, ms=800, pos=None):
        self.setText(text)
        self.adjustSize()
        if pos:
            self.move(pos)
        self.show()
        self.raise_()
        self._timer.start(ms)


