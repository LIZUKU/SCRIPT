def pr_ensure_face_component_mode():
    try:
        cmds.selectMode(component=True)
    except Exception:
        pass
    try:
        cmds.selectType(facet=True)
    except Exception:
        pass


def pr_force_selection_faces_only():
    try:
        cmds.ConvertSelectionToFaces()
    except Exception:
        pass
    try:
        sel = cmds.ls(sl=True, fl=True) or []
        only_faces = [c for c in sel if ".f[" in c]
        cmds.select(only_faces, replace=True)
    except Exception:
        pass
    pr_ensure_face_component_mode()


def pr_get_mesh_from_selection():
    sel = cmds.ls(selection=True, long=True) or []
    if not sel:
        return None
    obj = sel[0].split(".")[0] if "." in sel[0] else sel[0]
    shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []
    for s in shapes:
        if cmds.nodeType(s) == "mesh":
            return obj
    if cmds.nodeType(obj) == "mesh":
        p = cmds.listRelatives(obj, parent=True, fullPath=True)
        return p[0] if p else None
    return None


def pr_get_camera_direction():
    try:
        panel = cmds.getPanel(withFocus=True)
        if not panel or cmds.getPanel(typeOf=panel) != "modelPanel":
            panels = cmds.getPanel(type="modelPanel") or []
            panel = panels[0] if panels else None
        if panel:
            camera = cmds.modelPanel(panel, q=True, camera=True)
            cam_matrix = cmds.xform(camera, q=True, m=True, ws=True)
            direction = [cam_matrix[8], cam_matrix[9], cam_matrix[10]]
            return direction
    except Exception:
        pass
    return [0, 0, 1]


def pr_parse_face_index(comp):
    m = re.search(r"\.f\[(\d+)\]", comp)
    if not m:
        return None
    return int(m.group(1))


def pr_parse_edge_index(comp):
    m = re.search(r"\.e\[(\d+)\]", comp)
    if not m:
        return None
    return int(m.group(1))


def pr_get_dagpath_and_fnmesh(mesh_transform):
    if not om2:
        return None, None
    try:
        sel = om2.MSelectionList()
        sel.add(mesh_transform)
        dag = sel.getDagPath(0)
        if dag.apiType() != om2.MFn.kMesh:
            dag.extendToShape()
        fn = om2.MFnMesh(dag)
        return dag, fn
    except Exception:
        return None, None


def pr_get_selection_scope(mesh, target, source_selection=None):
    """
    Convert current/component selection to a stable scope for one mesh.
    target: "faces" or "edges"
    Returns:
      - None => no explicit component scope (object mode / whole mesh behavior)
      - list[str] => deduplicated components on the mesh
    """
    if target not in ("faces", "edges"):
        return None
    if not mesh or not cmds.objExists(mesh):
        return None

    sel = source_selection if source_selection is not None else (cmds.ls(sl=True, fl=True, long=True) or [])
    if not sel:
        return None

    mesh_long = cmds.ls(mesh, long=True) or [mesh]
    mesh_long = mesh_long[0]
    shape_paths = cmds.listRelatives(mesh_long, shapes=True, fullPath=True) or []
    mesh_shapes = set([s for s in shape_paths if cmds.nodeType(s) == "mesh"])

    mesh_items = []
    has_component_on_mesh = False
    for item in sel:
        if "." in item:
            base = item.split(".")[0]
            base_long = cmds.ls(base, long=True) or [base]
            base_long = base_long[0]
            if base_long == mesh_long:
                has_component_on_mesh = True
                mesh_items.append(item)
        else:
            item_long = cmds.ls(item, long=True) or [item]
            item_long = item_long[0]
            if item_long == mesh_long:
                mesh_items.append(item)
                continue
            if item_long in mesh_shapes:
                has_component_on_mesh = True
                mesh_items.append(item)

    if not mesh_items:
        return None
    if not has_component_on_mesh:
        # Object mode / transform selection => keep existing "full mesh" behavior.
        return None

    conv_kwargs = dict(fromFace=True, fromEdge=True, fromVertex=True, fromVertexFace=True, fromUV=True)
    if target == "faces":
        conv = cmds.polyListComponentConversion(mesh_items, toFace=True, **conv_kwargs)
        comps = cmds.ls(conv, fl=True, long=True) or []
        parsed = []
        for c in comps:
            idx = pr_parse_face_index(c)
            if idx is not None:
                parsed.append("{}.f[{}]".format(mesh_long, idx))
    else:
        conv = cmds.polyListComponentConversion(mesh_items, toEdge=True, **conv_kwargs)
        comps = cmds.ls(conv, fl=True, long=True) or []
        parsed = []
        for c in comps:
            idx = pr_parse_edge_index(c)
            if idx is not None:
                parsed.append("{}.e[{}]".format(mesh_long, idx))

    if not parsed:
        return []

    dedup = []
    seen = set()
    for c in parsed:
        if c not in seen:
            seen.add(c)
            dedup.append(c)
    return dedup


# =============================================================================
# SHORTEST PATH TOOL - Rewritten to match EdgeSensei logic exactly
# =============================================================================
PR_SP_CTX     = "PRShortestPathCtx"
PR_SP_SET     = "preSelDisp"
PR_SP_RUNNING = False

_sp_sel_geo       = []
_sp_store_edges   = []
_sp_initial_list  = []
_sp_ctx           = PR_SP_CTX


def _sp_get_edge_number(comp):
    return int(comp.split("[")[-1].split("]")[0])


def _sp_ordered_vertices_from_edges(edge_list):
    if not edge_list:
        return []

    sel_edges = edge_list
    shape_node = cmds.listRelatives(sel_edges[0], fullPath=True, parent=True)
    if not shape_node:
        return []
    transform_node = cmds.listRelatives(shape_node[0], fullPath=True, parent=True)
    if not transform_node:
        return []

    edge_number_list = []
    for a in sel_edges:
        check_number = ((a.split(".")[1]).split("\n")[0]).split(" ")
        for c in check_number:
            find_number = "".join([n for n in c.split("|")[-1] if n.isdigit()])
            if find_number:
                edge_number_list.append(find_number)

    get_number = []
    for s in sel_edges:
        evlist = cmds.polyInfo(s, ev=True)
        if not evlist:
            continue
        check_number = ((evlist[0].split(":")[1]).split("\n")[0]).split(" ")
        for c in check_number:
            find_number = "".join([n for n in c.split("|")[-1] if n.isdigit()])
            if find_number:
                get_number.append(find_number)

    dup = set([x for x in get_number if get_number.count(x) > 1])
    get_head_tail = list(set(get_number) - dup)

    vtf_order = []
    final_list = []

    if len(get_head_tail) > 0:
        vtf_order.append(get_head_tail[0])
        count = 0
        while len(dup) > 0 and count < 100:
            check_vtx = transform_node[0] + ".vtx[" + vtf_order[-1] + "]"
            velist = cmds.polyInfo(check_vtx, ve=True)
            if not velist:
                break
            get_number2 = []
            check_number2 = ((velist[0].split(":")[1]).split("\n")[0]).split(" ")
            for c in check_number2:
                find_number = "".join([n for n in c.split("|")[-1] if n.isdigit()])
                if find_number:
                    get_number2.append(find_number)
            find_next_edge = None
            for g in get_number2:
                if g in edge_number_list:
                    find_next_edge = g
                    break
            if find_next_edge is None:
                break
            edge_number_list.remove(find_next_edge)
            check_vtx2 = transform_node[0] + ".e[" + find_next_edge + "]"
            find_vtx = cmds.polyInfo(check_vtx2, ev=True)
            if not find_vtx:
                break
            get_number3 = []
            check_number3 = ((find_vtx[0].split(":")[1]).split("\n")[0]).split(" ")
            for c in check_number3:
                find_number = "".join([n for n in c.split("|")[-1] if n.isdigit()])
                if find_number:
                    get_number3.append(find_number)
            got_next_vtx = None
            for g in get_number3:
                if g in dup:
                    got_next_vtx = g
                    break
            if got_next_vtx is None:
                break
            dup.discard(got_next_vtx)
            vtf_order.append(got_next_vtx)
            count += 1

        if len(get_head_tail) > 1:
            vtf_order.append(get_head_tail[1])

        for v in vtf_order:
            final_list.append(transform_node[0] + ".vtx[" + v + "]")

    return final_list


def _sp_get_edge_loop_groups(sel_edges):
    if not sel_edges:
        return []

    trans = sel_edges[0].split(".")[0]
    e2v_infos = cmds.polyInfo(sel_edges, ev=True)
    e2v_dict = {}
    f_edges = []

    for info in e2v_infos:
        ev_list = [int(i) for i in re.findall(r"\d+", info)]
        e2v_dict.update(dict([(ev_list[0], ev_list[1:])]))

    while True:
        try:
            start_edge, start_vtxs = e2v_dict.popitem()
        except Exception:
            break
        edges_grp = [start_edge]
        num = 0
        for vtx in start_vtxs:
            cur_vtx = vtx
            while True:
                next_edges = []
                for k in e2v_dict:
                    if cur_vtx in e2v_dict[k]:
                        next_edges.append(k)
                if next_edges:
                    if len(next_edges) == 1:
                        if num == 0:
                            edges_grp.append(next_edges[0])
                        else:
                            edges_grp.insert(0, next_edges[0])
                        next_vtxs = e2v_dict[next_edges[0]]
                        cur_vtx = [v for v in next_vtxs if v != cur_vtx][0]
                        e2v_dict.pop(next_edges[0])
                    else:
                        break
                else:
                    break
            num += 1
        f_edges.append(edges_grp)

    ret_edges = []
    for f in f_edges:
        collect_list = []
        for x in f:
            get_com = trans + ".e[" + str(x) + "]"
            collect_list.append(get_com)
        ret_edges.append(collect_list)
    return ret_edges


def _sp_setup_attrs(geo):
    for attr in ["start", "end", "nearest", "closeTo", "firstRun"]:
        if not cmds.attributeQuery(attr, node=geo, exists=True):
            cmds.addAttr(geo, at="long", ln=attr)


def _sp_ensure_creas_set():
    if not cmds.objExists(PR_SP_SET):
        cmds.createNode("creaseSet")
        cmds.rename(PR_SP_SET)
    cmds.setAttr(PR_SP_SET + ".creaseLevel", 1)


def _sp_cleanup():
    if cmds.objExists(PR_SP_SET):
        try:
            cmds.setAttr(PR_SP_SET + ".creaseLevel", 0)
        except Exception:
            pass
        try:
            cmds.delete(PR_SP_SET)
        except Exception:
            pass


def _sp_finish():
    global PR_SP_RUNNING

    PR_SP_RUNNING = False

    try:
        cmds.setToolTo("moveSuperContext")
    except Exception:
        pass
    try:
        cmds.polyOptions(dce=0)
    except Exception:
        pass

    _sp_cleanup()

    if cmds.draggerContext(PR_SP_CTX, exists=True):
        try:
            cmds.deleteUI(PR_SP_CTX)
        except Exception:
            pass


def _sp_press():
    global _sp_store_edges, _sp_sel_geo, _sp_initial_list

    if not _sp_sel_geo:
        _sp_finish()
        return

    geo = _sp_sel_geo[0]
    check_run = cmds.getAttr(geo + ".firstRun")

    if check_run == 0:
        cmds.setAttr(geo + ".firstRun", 1)
    else:
        cmds.setAttr(geo + ".firstRun", 2)

        get_edge_list = cmds.ls(sl=True, fl=True) or []
        _sp_store_edges = get_edge_list

        list_vtx = _sp_ordered_vertices_from_edges(get_edge_list)
        if len(list_vtx) > 0:
            list_head = list_vtx[0]
            list_end  = list_vtx[-1]

            if list_head in _sp_initial_list:
                cmds.setAttr(geo + ".start", _sp_get_edge_number(list_vtx[0]))
                cmds.setAttr(geo + ".end",   _sp_get_edge_number(list_vtx[-1]))
            else:
                cmds.setAttr(geo + ".start", _sp_get_edge_number(list_vtx[-1]))
                cmds.setAttr(geo + ".end",   _sp_get_edge_number(list_vtx[0]))
        else:
            _sp_finish()


def _sp_drag():
    global _sp_store_edges, _sp_sel_geo

    if not _sp_sel_geo:
        _sp_finish()
        return

    geo = _sp_sel_geo[0]
    check_run = cmds.getAttr(geo + ".firstRun")

    modifiers = cmds.getModifiers()

    vpX, vpY, _ = cmds.draggerContext(PR_SP_CTX, query=True, dragPoint=True)

    pos_om  = om.MPoint()
    dir_om  = om.MVector()
    hitpoint = om.MFloatPoint()

    try:
        omui.M3dView.active3dView().viewToWorld(int(vpX), int(vpY), pos_om, dir_om)
    except Exception:
        return

    pos2 = om.MFloatPoint(pos_om.x, pos_om.y, pos_om.z)

    hit_face_ptr = om.MScriptUtil().asIntPtr()
    hit_face_id  = None
    final_x = final_y = final_z = 0.0

    try:
        sel_list = om.MSelectionList()
        sel_list.add(geo)
        dag_path = om.MDagPath()
        sel_list.getDagPath(0, dag_path)
        fn_mesh = om.MFnMesh(dag_path)

        intersection = fn_mesh.closestIntersection(
            om.MFloatPoint(pos2),
            om.MFloatVector(dir_om),
            None, None, False,
            om.MSpace.kWorld,
            99999, False, None,
            hitpoint, None,
            hit_face_ptr,
            None, None, None
        )

        if not intersection:
            return

        final_x = hitpoint.x
        final_y = hitpoint.y
        final_z = hitpoint.z
        hit_face_id = om.MScriptUtil(hit_face_ptr).asInt()

    except Exception:
        return

    hit_face_name = geo + ".f[" + str(hit_face_id) + "]"
    cv_list_raw = cmds.polyInfo(hit_face_name, fv=True)
    if not cv_list_raw:
        return

    cv_list = cv_list_raw[0].split(":")[-1].split("  ")
    most_close_cv_point = None
    short_distance_check = 10000.0

    for v in cv_list:
        check_number = "".join([n for n in v.split("|")[-1] if n.isdigit()])
        if len(check_number) > 0:
            cv_point    = geo + ".vtx[" + str(check_number) + "]"
            cv_position = cmds.pointPosition(cv_point)
            check_cv_distance = math.sqrt(
                (float(cv_position[0]) - final_x) ** 2 +
                (float(cv_position[1]) - final_y) ** 2 +
                (float(cv_position[2]) - final_z) ** 2
            )
            if check_cv_distance < short_distance_check:
                short_distance_check = check_cv_distance
                most_close_cv_point  = cv_point

    if most_close_cv_point is None:
        return

    new_id = _sp_get_edge_number(most_close_cv_point)
    cmds.setAttr(geo + ".nearest", new_id)

    if check_run == 1:
        check_close_to = cmds.getAttr(geo + ".nearest")
        check_start    = cmds.getAttr(geo + ".start")
        check_end      = cmds.getAttr(geo + ".end")

        start_position = cmds.pointPosition(geo + ".vtx[" + str(check_start) + "]")
        end_position   = cmds.pointPosition(geo + ".vtx[" + str(check_end)   + "]")
        near_position  = cmds.pointPosition(geo + ".vtx[" + str(check_close_to) + "]")

        dist_a = math.sqrt(
            (float(near_position[0]) - start_position[0]) ** 2 +
            (float(near_position[1]) - start_position[1]) ** 2 +
            (float(near_position[2]) - start_position[2]) ** 2
        )
        dist_b = math.sqrt(
            (float(near_position[0]) - end_position[0]) ** 2 +
            (float(near_position[1]) - end_position[1]) ** 2 +
            (float(near_position[2]) - end_position[2]) ** 2
        )

        if dist_a > dist_b:
            cmds.setAttr(geo + ".end",   check_end)
            cmds.setAttr(geo + ".start", check_start)
        else:
            cmds.setAttr(geo + ".end",   check_start)
            cmds.setAttr(geo + ".start", check_end)

    check_start   = cmds.getAttr(geo + ".start")
    check_nearest = cmds.getAttr(geo + ".nearest")

    sort_list = []
    if modifiers == 4:
        pa = geo + ".vtx[" + str(check_start) + "]"
        pb = geo + ".vtx[" + str(check_nearest) + "]"
        uva = cmds.polyListComponentConversion(pa, fv=True, tuv=True) or []
        uvb = cmds.polyListComponentConversion(pb, fv=True, tuv=True) or []
        if uva and uvb:
            start_uv_id = _sp_get_edge_number(uva[0])
            end_uv_id   = _sp_get_edge_number(uvb[0])
            list_short  = cmds.polySelect(geo, q=True,
                                          shortestEdgePathUV=(start_uv_id, end_uv_id))
            if list_short:
                sort_list = [geo + ".e[" + str(l) + "]" for l in list_short]
    else:
        list_short = cmds.polySelect(geo, q=True,
                                     shortestEdgePath=(check_start, check_nearest))
        if list_short:
            sort_list = [geo + ".e[" + str(l) + "]" for l in list_short]

    get_c = _sp_store_edges + sort_list

    cmds.select(get_c)
    _sp_ensure_creas_set()
    try:
        cmds.sets(geo + ".e[*]", remove=PR_SP_SET)
    except Exception:
        pass
    if get_c:
        cmds.sets(get_c, forceElement=PR_SP_SET)

    cmds.refresh(cv=True, f=True)


def _sp_release():
    pass


def _sp_start_interactive(geo, edge_list):
    global _sp_store_edges, _sp_sel_geo, _sp_initial_list, _sp_ctx

    _sp_store_edges = cmds.ls(sl=True, fl=True) or []
    list_vtx = _sp_ordered_vertices_from_edges(_sp_store_edges)

    if not list_vtx:
        cmds.warning("[PR] Cannot order edge chain vertices.")
        return

    _sp_initial_list = list_vtx

    start_id = _sp_get_edge_number(list_vtx[0])
    end_id   = _sp_get_edge_number(list_vtx[-1])

    cmds.setAttr(geo + ".start",    start_id)
    cmds.setAttr(geo + ".end",      end_id)
    cmds.setAttr(geo + ".firstRun", 0)

    _sp_ensure_creas_set()
    try:
        cmds.sets(geo + ".e[*]", remove=PR_SP_SET)
    except Exception:
        pass
    cmds.sets(_sp_store_edges, forceElement=PR_SP_SET)

    cmds.polyOptions(dce=1)

    if cmds.draggerContext(PR_SP_CTX, exists=True):
        cmds.deleteUI(PR_SP_CTX)

    cmds.draggerContext(
        PR_SP_CTX,
        pressCommand   = _sp_press,
        releaseCommand = _sp_release,
        dragCommand    = _sp_drag,
        fnz            = _sp_finish,
        name           = PR_SP_CTX,
        cursor         = "crossHair",
        undoMode       = "step"
    )
    cmds.setToolTo(PR_SP_CTX)


def pr_shortest_path_select(use_uv=False):
    global _sp_sel_geo, _sp_store_edges, _sp_initial_list, PR_SP_RUNNING

    _sp_finish()
    PR_SP_RUNNING = True

    test_any_sel = cmds.ls(sl=True) or []
    if not test_any_sel:
        cmds.warning("[PR] Nothing selected.")
        PR_SP_RUNNING = False
        return 0

    check_edge_sel  = cmds.filterExpand(sm=32) or []
    check_other_sel = cmds.filterExpand(sm=(31, 34, 35)) or []

    verts = cmds.filterExpand(cmds.ls(sl=True, fl=True), sm=31) or []
    if len(verts) == 2 and not check_edge_sel:
        mesh_a = verts[0].split(".")[0]
        mesh_b = verts[1].split(".")[0]
        if mesh_a != mesh_b:
            cmds.warning("[PR] Both vertices must be on the same mesh.")
            PR_SP_RUNNING = False
            return 0

        geo = mesh_a
        id_a = _sp_get_edge_number(verts[0])
        id_b = _sp_get_edge_number(verts[1])
        result = cmds.polySelect(geo, q=True, shortestEdgePath=(id_a, id_b))
        if result:
            edges = [geo + ".e[" + str(e) + "]" for e in result]
            cmds.select(edges, r=True)
            try:
                mel.eval('doMenuComponentSelectionExt("' + geo + '", "edge", 0);')
            except Exception:
                pass
            cmds.select(edges, r=True)
            PR_SP_RUNNING = False
            return len(edges)
        PR_SP_RUNNING = False
        return 0

    if len(check_edge_sel) == 2:
        mesh_a = check_edge_sel[0].split(".")[0]
        mesh_b = check_edge_sel[1].split(".")[0]
        if mesh_a != mesh_b:
            cmds.warning("[PR] Both edges must be on the same mesh.")
            PR_SP_RUNNING = False
            return 0

        geo = mesh_a
        e1_verts = cmds.ls(cmds.polyListComponentConversion(check_edge_sel[0], tv=True), fl=True) or []
        e2_verts = cmds.ls(cmds.polyListComponentConversion(check_edge_sel[1], tv=True), fl=True) or []

        best_path = []
        for a in e1_verts:
            for b in e2_verts:
                result = cmds.polySelect(geo, q=True,
                                         shortestEdgePath=(_sp_get_edge_number(a),
                                                           _sp_get_edge_number(b)))
                if result and (not best_path or len(result) < len(best_path)):
                    best_path = result

        if best_path:
            edges = [geo + ".e[" + str(e) + "]" for e in best_path]
            cmds.select(edges, r=True)
            try:
                mel.eval('doMenuComponentSelectionExt("' + geo + '", "edge", 0);')
            except Exception:
                pass
            cmds.select(edges, r=True)
            PR_SP_RUNNING = False
            return len(edges)

        cmds.warning("[PR] No shortest path found between selected edges.")
        PR_SP_RUNNING = False
        return 0

    if check_edge_sel:
        loop_grp = _sp_get_edge_loop_groups(check_edge_sel)
        if len(loop_grp) != 1:
            cmds.select(check_edge_sel)

        list_vtx = _sp_ordered_vertices_from_edges(check_edge_sel)
        if not list_vtx:
            cmds.warning("[PR] Please select a simple open edge chain.")
            PR_SP_RUNNING = False
            return 0

        check_poly = cmds.ls(hl=True) or []
        if check_poly:
            geo = check_poly[0]
        else:
            geo = check_edge_sel[0].split(".")[0]

        _sp_sel_geo = [geo]

        _sp_setup_attrs(geo)
        cmds.setAttr(geo + ".firstRun", 0)

        cmds.select(check_edge_sel, r=True)
        try:
            mel.eval('doMenuComponentSelectionExt("' + geo + '", "edge", 0);')
        except Exception:
            pass
        cmds.select(check_edge_sel, r=True)

        _sp_start_interactive(geo, check_edge_sel)
        return len(check_edge_sel)

    if check_other_sel:
        check_poly = cmds.ls(hl=True) or []
    else:
        check_poly = cmds.ls(sl=True, fl=True, o=True) or []

    if not check_poly:
        cmds.warning("[PR] Select a mesh or an edge chain.")
        PR_SP_RUNNING = False
        return 0

    geo = check_poly[0]
    _sp_sel_geo = [geo]

    _sp_setup_attrs(geo)

    try:
        mel.eval('doMenuComponentSelectionExt("' + geo + '", "edge", 0);')
    except Exception:
        pass
    cmds.select(cl=True)

    cmds.setAttr(geo + ".firstRun", 0)

    _sp_ensure_creas_set()
    try:
        cmds.sets(geo + ".e[*]", remove=PR_SP_SET)
    except Exception:
        pass

    _sp_store_edges = []
    _sp_initial_list = []

    if cmds.draggerContext(PR_SP_CTX, exists=True):
        cmds.deleteUI(PR_SP_CTX)

    cmds.draggerContext(
        PR_SP_CTX,
        pressCommand   = _sp_press_from_object,
        releaseCommand = _sp_release,
        dragCommand    = _sp_drag,
        fnz            = _sp_finish,
        name           = PR_SP_CTX,
        cursor         = "crossHair",
        undoMode       = "step"
    )
    cmds.setToolTo(PR_SP_CTX)

    print("[PR] Shortest Path: click an edge to start, then drag. Ctrl = UV mode.")
    return 0


def _sp_press_from_object():
    global _sp_store_edges, _sp_initial_list

    if not _sp_sel_geo:
        _sp_finish()
        return

    geo = _sp_sel_geo[0]
    check_run = cmds.getAttr(geo + ".firstRun")

    if check_run == 0:
        cmds.setAttr(geo + ".firstRun", 1)
        return

    _sp_press()


