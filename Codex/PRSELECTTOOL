    def _trigger_live_if_needed(self):
        if PR_SP_RUNNING:
            return
        if self._live:
            self._timer.start()

    def _set_dir(self, vec):
        self._direction = vec
        if self._live:
            self._do_live_select()

    def _use_camera(self):
        self._direction = pr_get_camera_direction()
        if self._live:
            self._do_live_select()

    def _on_angle_change(self):
        if self._live:
            self._timer.start()

    def _install_selection_changed_hook(self):
        try:
            if self._selection_job and cmds.scriptJob(exists=self._selection_job):
                cmds.scriptJob(kill=self._selection_job, force=True)
        except Exception:
            pass
        try:
            self._selection_job = cmds.scriptJob(
                event=["SelectionChanged", self._on_selection_changed],
                parent=self.objectName()
            )
        except Exception:
            self._selection_job = None

    def _on_selection_changed(self):
        if self._ignore_selection_changed:
            return
        self._clear_angle_scope_seed()
        self._clear_hard_scope_seed()

    def _capture_angle_scope_seed(self):
        mesh = pr_get_mesh_from_selection()
        self._angle_scope_seed = pr_get_selection_scope(mesh, "faces") if mesh else None

    def _clear_angle_scope_seed(self):
        self._angle_scope_seed = None

    def _capture_hard_scope_seed(self):
        mesh = pr_get_mesh_from_selection()
        self._hard_scope_seed = pr_get_selection_scope(mesh, "edges") if mesh else None

    def _clear_hard_scope_seed(self):
        self._hard_scope_seed = None

    def _do_live_select(self):
        if PR_SP_RUNNING:
            return
        if self._angle_scope_seed is None:
            self._capture_angle_scope_seed()
        self._ignore_selection_changed = True
        try:
            PR_SelectByAngle.run(
                self.angle_spin.value(),
                self._direction,
                both=self.both_chk.isChecked(),
                plane_ref=self._plane_ref if self.plane_chk.isChecked() else None,
                plane_tol=self.plane_tol.value(),
                scope_selection=self._angle_scope_seed,
            )
        finally:
            self._ignore_selection_changed = False

    def _use_face(self):
        normal, plane_ref = PR_SelectByAngle.get_face_normal_and_plane_ref()
        if normal:
            self._direction = normal
            self._plane_ref = plane_ref if plane_ref and plane_ref[0] and plane_ref[1] else None
            if self._live:
                self._do_live_select()

    def _select_angle(self):
        if self._angle_scope_seed is None:
            self._capture_angle_scope_seed()
        self._ignore_selection_changed = True
        try:
            PR_SelectByAngle.run(
                self.angle_spin.value(),
                self._direction,
                both=self.both_chk.isChecked(),
                plane_ref=self._plane_ref if self.plane_chk.isChecked() else None,
                plane_tol=self.plane_tol.value(),
                scope_selection=self._angle_scope_seed,
            )
        finally:
            self._ignore_selection_changed = False
            self._clear_angle_scope_seed()

    def _set_skip(self, n):
        self._skip = n
        self.skip_spin.setValue(n)
        for val, btn in self.skip_btns.items():
            btn.set_active(val == n)

    def _set_mode(self, mode):
        self._edge_mode = mode
        self.loop_btn.set_active(mode == 1)
        self.ring_btn.set_active(mode == 2)
        self.both_btn.set_active(mode == 3)

    def _select_pattern(self):
        PR_SelectTools.select_pattern(self._skip, self._edge_mode, self.edge_inv_chk.isChecked())

    def _update_hard(self):
        if self._hard_scope_seed is None:
            self._capture_hard_scope_seed()
        self._ignore_selection_changed = True
        try:
            PR_SelectTools.select_hard_edges(
                self.min_spin.value(),
                self.max_spin.value(),
                scope_selection=self._hard_scope_seed
            )
        finally:
            self._ignore_selection_changed = False

    def _select_all_hard_edges(self):
        mesh = pr_get_mesh_from_selection()
        scope = pr_get_selection_scope(mesh, "edges") if mesh else None
        self._ignore_selection_changed = True
        try:
            PR_SelectTools.select_all_hard_edges(scope_selection=scope)
        finally:
            self._ignore_selection_changed = False
            self._clear_hard_scope_seed()

    def _select_smoothing_hard_edges(self):
        mesh = pr_get_mesh_from_selection()
        scope = pr_get_selection_scope(mesh, "edges") if mesh else None
        self._ignore_selection_changed = True
        try:
            PR_SelectTools.select_smoothing_hard_edges(scope_selection=scope)
        finally:
            self._ignore_selection_changed = False
            self._clear_hard_scope_seed()

    def _select_border_edges(self):
        mesh = pr_get_mesh_from_selection()
        scope = pr_get_selection_scope(mesh, "edges") if mesh else None
        self._ignore_selection_changed = True
        try:
            PR_SelectTools.select_border_edges(scope_selection=scope)
        finally:
            self._ignore_selection_changed = False
            self._clear_hard_scope_seed()

    def _run_identical_mesh_search(self):
        count = PR_SelectTools.select_identical_meshes()
        if count > 0:
            msg = "{} identical".format(count)
            pos = self.similar_btn.mapToGlobal(QtCore.QPoint(0, -25))
            self._toast.show_msg(msg, 900, pos)

    def _show_similar_context_menu(self, pos):
        menu = QtWidgets.QMenu(self)
        method_menu = menu.addMenu("Method")
        ag = QtGui.QActionGroup(menu)
        ag.setExclusive(True)
        for key, label in [("topology","Topology"),("geometry","Geometry"),("exact","Exact")]:
            act = method_menu.addAction(label)
            act.setCheckable(True)
            act.setChecked(PR_SelectTools.identical_method == key)
            act.triggered.connect(lambda checked=False, m=key: PR_SelectTools.set_identical_method(m))
            ag.addAction(act)
        menu.addSeparator()
        ignore_act = menu.addAction("Ignore Scale")
        ignore_act.setCheckable(True)
        ignore_act.setChecked(PR_SelectTools.identical_ignore_scale)
        ignore_act.toggled.connect(lambda state: PR_SelectTools.set_identical_ignore_scale(state))
        mat_act = menu.addAction("Same Material Only")
        mat_act.setCheckable(True)
        mat_act.setChecked(PR_SelectTools.identical_filter_material)
        mat_act.toggled.connect(lambda state: PR_SelectTools.set_identical_filter_material(state))
        menu.addSeparator()
        tol_act = menu.addAction("Set Tolerance...")
        tol_act.triggered.connect(self._prompt_identical_tolerance)
        run_act = menu.addAction("Run Similar")
        run_act.triggered.connect(self._run_identical_mesh_search)
        gp = self.similar_btn.mapToGlobal(pos)
        if hasattr(menu, "exec"):
            menu.exec(gp)
        else:
            menu.exec_(gp)

    def _prompt_identical_tolerance(self):
        value, ok = QtWidgets.QInputDialog.getDouble(
            self, "Similar Tolerance", "Tolerance:",
            PR_SelectTools.identical_tolerance, 0.0001, 10.0, 4)
        if ok:
            PR_SelectTools.set_identical_tolerance(value)

    def _save_slot(self, slot):
        count = PR_SelectTools.save(slot)
        if count > 0:
            self.save_btns[slot].set_has_data(True)
            self.load_btns[slot].set_has_data(True)
            pos = self.save_btns[slot].mapToGlobal(QtCore.QPoint(0, -25))
            self._toast.show_msg("{}".format(count), 700, pos)

    def _load_slot(self, slot):
        if PR_SelectTools.load(slot):
            pos = self.load_btns[slot].mapToGlobal(QtCore.QPoint(0, -25))
            self._toast.show_msg("Loaded", 500, pos)

    def _create_set(self):
        sel = cmds.ls(sl=True, fl=True) or []
        if not sel:
            return
        result = cmds.promptDialog(
            title="Create Set", message="Name:",
            button=["OK","Cancel"], defaultButton="OK",
            cancelButton="Cancel"
        )
        if result == "OK":
            name = cmds.promptDialog(q=True, text=True)
            if name:
                cmds.sets(sel, name=name)

    def _delete_set_menu(self, pos):
        menu = QtWidgets.QMenu(self)
        menu.setStyleSheet(
            "QMenu { background-color: #2a2a2a; color: #a0a0a0; }"
            " QMenu::item:selected { background-color: #3a3a3a; }"
        )
        all_sets = cmds.ls(type="objectSet") or []
        user_sets = [
            s for s in all_sets
            if not s.startswith("default")
            and ":" not in s
            and not s.startswith("initial")
            and s not in ["initialParticleSE", "initialShadingGroup"]
        ]
        if user_sets:
            for s in user_sets[:20]:
                action = menu.addAction("Delete " + s)
                action.triggered.connect(lambda checked=False, name=s: cmds.delete(name))
        else:
            menu.addAction("No sets").setEnabled(False)
        gp = self.set_btn.mapToGlobal(pos)
        if hasattr(menu, "exec"):
            menu.exec(gp)
        else:
            menu.exec_(gp)

    @classmethod
    def show_ui(cls):
        if cls._instance:
            try:
                cls._instance.close()
                cls._instance.deleteLater()
            except Exception:
                pass
        cls._instance = cls()
        cls._instance.show()
        return cls._instance


