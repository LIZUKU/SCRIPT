# EDGE & FACE TOOLS
# =============================================================================
class PR_SelectTools:
    saved_slots = [None, None, None]

    identical_method          = "geometry"
    identical_ignore_scale    = True
    identical_filter_material = False
    identical_tolerance       = 0.01

    @staticmethod
    def _parse_edge_component(edge_comp):
        m = re.search(r"^(.*)\.e\[(\d+)\]$", edge_comp)
        if not m:
            return None, None
        return m.group(1), int(m.group(2))

    @staticmethod
    def _build_edge_components(mesh, edge_ids):
        return ["{}.e[{}]".format(mesh, i) for i in edge_ids]

    @classmethod
    def _get_edge_path_indices(cls, mesh, start_idx, end_idx, mode):
        candidates = []
        if mode in (1, 3):
            try:
                loop_path = cmds.polySelect(mesh, edgeLoopPath=(start_idx, end_idx), noSelection=True) or []
                if loop_path:
                    candidates.append(loop_path)
            except Exception:
                pass
        if mode in (2, 3):
            try:
                ring_path = cmds.polySelect(mesh, edgeRingPath=(start_idx, end_idx), noSelection=True) or []
                if ring_path:
                    candidates.append(ring_path)
            except Exception:
                pass
        if not candidates:
            return []
        candidates.sort(key=len)
        return candidates[0]

    @classmethod
    def _apply_pattern_on_path(cls, mesh, path_indices, skip, invert=False):
        if not path_indices:
            cmds.select(clear=True)
            return 0
        skip   = max(2, int(skip))
        picked = []
        for i, edge_id in enumerate(path_indices):
            if i % skip == 0:
                picked.append(edge_id)
        if path_indices[-1] not in picked:
            picked.append(path_indices[-1])
        seen    = set()
        ordered = []
        for e in picked:
            if e not in seen:
                seen.add(e)
                ordered.append(e)
        comps = cls._build_edge_components(mesh, ordered)
        if invert:
            edge_count = cmds.polyEvaluate(mesh, edge=True)
            all_edges  = ["{}.e[{}]".format(mesh, i) for i in range(edge_count)]
            final_sel  = [e for e in all_edges if e not in comps]
            cmds.select(final_sel, r=True)
            return len(final_sel)
        cmds.select(comps, r=True)
        return len(comps)

    @classmethod
    def select_pattern(cls, skip, mode, invert=False):
        sel   = cmds.ls(sl=True, fl=True) or []
        edges = [s for s in sel if ".e[" in s]
        if not edges:
            cmds.warning("[PR] Select edges.")
            return 0

        if len(edges) == 2:
            mesh_a, edge_a = cls._parse_edge_component(edges[0])
            mesh_b, edge_b = cls._parse_edge_component(edges[1])
            if mesh_a is None or mesh_b is None or edge_a is None or edge_b is None:
                cmds.warning("[PR] Invalid edge selection.")
                return 0
            if mesh_a != mesh_b:
                cmds.warning("[PR] Please select 2 edges on the same mesh.")
                return 0
            path_indices = cls._get_edge_path_indices(mesh_a, edge_a, edge_b, mode)
            if not path_indices:
                cmds.warning("[PR] No valid loop/ring path found between selected edges.")
                return 0
            return cls._apply_pattern_on_path(mesh_a, path_indices, skip, invert=invert)

        if mode in [1, 3]:
            mel.eval('polySelectEdgesEveryN "edgeLoop" {}'.format(skip))
        if mode in [2, 3]:
            mel.eval('polySelectEdgesEveryN "edgeRing" {}'.format(skip))
        if invert:
            cmds.InvertSelection()
        return len(cmds.ls(sl=True, fl=True) or [])

    @classmethod
    def select_all_hard_edges(cls, scope_selection=None):
        sel = cmds.ls(sl=True, o=True) or []
        if not sel:
            cmds.warning("[PR] Select a mesh object first.")
            return 0
        cmds.selectMode(component=True)
        cmds.selectType(edge=True)
        edge_count = cmds.polyEvaluate(sel[0], edge=True)
        cmds.select("{}.e[0:{}]".format(sel[0], edge_count-1), r=True)
        cmds.polySelectConstraint(m=3, t=0x8000, angle=True, anglebound=(30, 180))
        cmds.polySelectConstraint(disable=True)
        result = cmds.ls(sl=True, fl=True) or []
        if scope_selection is not None:
            result = [e for e in result if e in set(scope_selection)]
            cmds.select(result, r=True)
        return len(result)

    @classmethod
    def select_smoothing_hard_edges(cls, scope_selection=None):
        mesh = pr_get_mesh_from_selection()
        if not mesh:
            cmds.warning("[PR] Select a mesh object first.")
            return 0

        try:
            cmds.selectMode(component=True)
            cmds.selectType(edge=True)
        except Exception:
            pass

        hard_edges = []

        if om2:
            try:
                sel_list = om2.MSelectionList()
                sel_list.add(mesh)
                dag = sel_list.getDagPath(0)
                if dag.apiType() != om2.MFn.kMesh:
                    dag.extendToShape()

                it = om2.MItMeshEdge(dag)
                while not it.isDone():
                    try:
                        is_smooth = it.isSmooth()
                    except TypeError:
                        is_smooth = it.isSmooth

                    if not is_smooth:
                        hard_edges.append("{}.e[{}]".format(mesh, it.index()))
                    it.next()

            except Exception as e:
                cmds.warning("[PR] Smoothing hard edges (om2) failed: {}".format(e))
                hard_edges = []

        if not hard_edges:
            try:
                edge_count = cmds.polyEvaluate(mesh, edge=True)
                if edge_count and edge_count > 0:
                    cmds.select("{}.e[0:{}]".format(mesh, edge_count - 1), r=True)
                    cmds.polySelectConstraint(m=3, t=0x8000, smoothness=1)
                    cmds.polySelectConstraint(disable=True)
                    hard_edges = cmds.ls(sl=True, fl=True) or []
            except Exception as e:
                try:
                    cmds.polySelectConstraint(disable=True)
                except Exception:
                    pass
                cmds.warning("[PR] Smoothing hard edges fallback failed: {}".format(e))
                hard_edges = []

        if hard_edges:
            if scope_selection is not None:
                scope_set = set(scope_selection)
                hard_edges = [e for e in hard_edges if e in scope_set]
            cmds.select(hard_edges, r=True)
            return len(hard_edges)

        cmds.select(clear=True)
        cmds.warning("[PR] No smoothing hard edges found.")
        return 0

    @classmethod
    def select_border_edges(cls, scope_selection=None):
        mesh = pr_get_mesh_from_selection()
        if not mesh:
            cmds.warning("[PR] Select a mesh object first.")
            return 0
        try:
            cmds.selectMode(component=True)
            cmds.selectType(edge=True)
        except Exception:
            pass
        edges = []
        if om2:
            try:
                sel_list = om2.MSelectionList()
                sel_list.add(mesh)
                dag = sel_list.getDagPath(0)
                if dag.apiType() != om2.MFn.kMesh:
                    dag.extendToShape()
                it = om2.MItMeshEdge(dag)
                while not it.isDone():
                    if it.onBoundary():
                        edges.append("{}.e[{}]".format(mesh, it.index()))
                    it.next()
            except Exception as e:
                cmds.warning("[PR] Border edges (om2) failed: {}".format(e))
                edges = []
        if not edges:
            try:
                edge_count = cmds.polyEvaluate(mesh, edge=True)
                if edge_count and edge_count > 0:
                    cmds.select("{}.e[0:{}]".format(mesh, edge_count-1), r=True)
                    cmds.polySelectConstraint(m=3, t=0x8000, where=1)
                    cmds.polySelectConstraint(disable=True)
                    edges = cmds.ls(sl=True, fl=True) or []
            except Exception as e:
                try:
                    cmds.polySelectConstraint(disable=True)
                except Exception:
                    pass
                cmds.warning("[PR] Border edges (constraint) failed: {}".format(e))
                edges = []
        if edges:
            if scope_selection is not None:
                scope_set = set(scope_selection)
                edges = [e for e in edges if e in scope_set]
            cmds.select(edges, r=True)
            return len(edges)
        cmds.select(clear=True)
        cmds.warning("[PR] No border edges found.")
        return 0

    @classmethod
    def select_hard_edges(cls, min_a, max_a, scope_selection=None):
        sel = cmds.ls(sl=True, o=True) or []
        if not sel:
            return 0
        mesh = sel[0]
        try:
            cmds.selectMode(component=True)
            cmds.selectType(edge=True)
        except Exception:
            pass
        edge_count = cmds.polyEvaluate(mesh, edge=True)
        if not edge_count:
            return 0
        try:
            cmds.select("{}.e[0:{}]".format(mesh, edge_count-1), r=True)
            cmds.polySelectConstraint(m=3, t=0x8000, angle=True, anglebound=(min_a, max_a))
            result = cmds.ls(sl=True, fl=True) or []
        finally:
            try:
                cmds.polySelectConstraint(disable=True)
            except Exception:
                pass
        if scope_selection is not None:
            scope_set = set(scope_selection)
            result = [e for e in result if e in scope_set]
            cmds.select(result, r=True)
        return len(result)

    @classmethod
    def select_creased(cls):
        sel = cmds.ls(sl=True) or []
        if not sel:
            return 0
        if cmds.objectType(sel[0]) != "transform":
            cmds.selectMode(object=True)
            sel = cmds.ls(sl=True, o=True) or []
        cmds.selectMode(component=True)
        cmds.selectType(edge=True)
        edge_count = cmds.polyEvaluate(sel[0], edge=True)
        cmds.select("{}.e[0:{}]".format(sel[0], edge_count-1), r=True)
        all_e   = cmds.filterExpand(cmds.polyListComponentConversion(te=True), sm=32, expand=True) or []
        creased = []
        for e in all_e:
            try:
                if cmds.polyCrease(e, q=True, v=True)[0] > 0:
                    creased.append(e)
            except Exception:
                pass
        if creased:
            cmds.select(creased, r=True)
            return len(creased)
        cmds.select(clear=True)
        return 0

    @classmethod
    def select_contiguous_by_angle(cls, max_angle=60):
        pr_ensure_face_component_mode()
        sel         = cmds.ls(sl=True, fl=True) or []
        start_faces = [s for s in sel if ".f[" in s]
        if not start_faces:
            cmds.warning("[PR] Select a face first.")
            return 0

        mesh = start_faces[0].split(".")[0]

        def get_normal(face):
            fi = pr_parse_face_index(face)
            if fi is None:
                return None
            dag, fn = pr_get_dagpath_and_fnmesh(mesh)
            if fn:
                n  = fn.getPolygonNormal(fi, om2.MSpace.kWorld)
                nl = n.length()
                if nl < 1e-8:
                    return None
                n = n / nl
                return [n.x, n.y, n.z]
            info = cmds.polyInfo(face, faceNormals=True)
            if not info:
                return None
            p  = info[0].split()
            n  = [float(p[2]), float(p[3]), float(p[4])]
            nl = math.sqrt(sum(v**2 for v in n))
            if nl < 1e-8:
                return None
            return [v/nl for v in n]

        def angle_between(n1, n2):
            dotv = sum(n1[i]*n2[i] for i in range(3))
            dotv = max(-1.0, min(1.0, dotv))
            return math.degrees(math.acos(dotv))

        selected = set(start_faces)
        to_check = list(start_faces)
        checked  = set()

        while to_check:
            face        = to_check.pop(0)
            if face in checked:
                continue
            checked.add(face)
            face_normal = get_normal(face)
            if not face_normal:
                continue
            edges     = cmds.polyListComponentConversion(face, fromFace=True, toEdge=True)
            edges     = cmds.ls(edges, fl=True) or []
            for edge in edges:
                adj_faces = cmds.polyListComponentConversion(edge, fromEdge=True, toFace=True)
                adj_faces = cmds.ls(adj_faces, fl=True) or []
                for adj in adj_faces:
                    if adj in selected or adj in checked:
                        continue
                    adj_normal = get_normal(adj)
                    if not adj_normal:
                        continue
                    if angle_between(face_normal, adj_normal) <= max_angle:
                        selected.add(adj)
                        to_check.append(adj)

        if selected:
            cmds.select(list(selected), replace=True)
            pr_force_selection_faces_only()
        return len(cmds.ls(sl=True, fl=True) or [])

    @classmethod
    def select_similar_faces(cls):
        pr_ensure_face_component_mode()
        sel   = cmds.ls(sl=True, fl=True) or []
        faces = [s for s in sel if ".f[" in s]
        if not faces:
            cmds.warning("[PR] Select a face first.")
            return 0

        mesh = faces[0].split(".")[0]
        fi   = pr_parse_face_index(faces[0])
        if fi is None:
            return 0

        ref     = None
        dag, fn = pr_get_dagpath_and_fnmesh(mesh)
        if fn:
            n  = fn.getPolygonNormal(fi, om2.MSpace.kWorld)
            nl = n.length()
            if nl < 1e-8:
                return 0
            n   = n / nl
            ref = [n.x, n.y, n.z]
        else:
            info = cmds.polyInfo(faces[0], faceNormals=True)
            if not info:
                return 0
            p  = info[0].split()
            ref = [float(p[2]), float(p[3]), float(p[4])]
            rl  = math.sqrt(sum(v**2 for v in ref))
            if rl < 1e-8:
                return 0
            ref = [v/rl for v in ref]

        cos_thresh = math.cos(math.radians(15))
        similar    = []

        if fn:
            for i in range(fn.numPolygons):
                n  = fn.getPolygonNormal(i, om2.MSpace.kWorld)
                nl = n.length()
                if nl < 1e-8:
                    continue
                n    = n / nl
                dotv = (n.x*ref[0]) + (n.y*ref[1]) + (n.z*ref[2])
                if dotv >= cos_thresh:
                    similar.append("{}.f[{}]".format(mesh, i))
        else:
            for i in range(cmds.polyEvaluate(mesh, face=True)):
                face = "{}.f[{}]".format(mesh, i)
                info = cmds.polyInfo(face, faceNormals=True)
                if not info:
                    continue
                p  = info[0].split()
                n  = [float(p[2]), float(p[3]), float(p[4])]
                nl = math.sqrt(sum(v**2 for v in n))
                if nl < 1e-8:
                    continue
                n    = [v/nl for v in n]
                dotv = sum(n[j]*ref[j] for j in range(3))
                if dotv >= cos_thresh:
                    similar.append(face)

        if similar:
            cmds.select(similar, replace=True)
            pr_force_selection_faces_only()
        return len(cmds.ls(sl=True, fl=True) or [])

    @classmethod
    def select_identical_meshes(cls):
        return len(pr_find_identical_meshes(
            method=cls.identical_method,
            tolerance=cls.identical_tolerance,
            source_mesh=None,
            ignore_scale=cls.identical_ignore_scale,
            filter_by_material=cls.identical_filter_material,
            select_result=True
        ))

    @classmethod
    def set_identical_method(cls, method):
        cls.identical_method = method

    @classmethod
    def set_identical_ignore_scale(cls, state):
        cls.identical_ignore_scale = bool(state)

    @classmethod
    def set_identical_filter_material(cls, state):
        cls.identical_filter_material = bool(state)

    @classmethod
    def set_identical_tolerance(cls, value):
        cls.identical_tolerance = max(0.0001, float(value))

    @classmethod
    def select_ngons(cls):
        sel = cmds.ls(sl=True, o=True) or []
        if not sel:
            cmds.warning("[PR] Select an object.")
            return 0
        pr_ensure_face_component_mode()
        face_count = cmds.polyEvaluate(sel[0], face=True)
        cmds.select("{}.f[0:{}]".format(sel[0], face_count-1), r=True)
        cmds.polySelectConstraint(m=3, t=0x0008, size=3)
        cmds.polySelectConstraint(disable=True)
        pr_force_selection_faces_only()
        return len(cmds.ls(sl=True, fl=True) or [])

    @classmethod
    def select_tris(cls):
        sel = cmds.ls(sl=True, o=True) or []
        if not sel:
            cmds.warning("[PR] Select an object.")
            return 0
        pr_ensure_face_component_mode()
        face_count = cmds.polyEvaluate(sel[0], face=True)
        cmds.select("{}.f[0:{}]".format(sel[0], face_count-1), r=True)
        cmds.polySelectConstraint(m=3, t=0x0008, size=1)
        cmds.polySelectConstraint(disable=True)
        pr_force_selection_faces_only()
        return len(cmds.ls(sl=True, fl=True) or [])

    @classmethod
    def unlock_normals(cls):
        try:
            cmds.polyNormalPerVertex(ufn=True)
        except Exception:
            try:
                mel.eval("UnlockNormals;")
            except Exception:
                pass

    @classmethod
    def save(cls, slot):
        sel = cmds.ls(sl=True, fl=True) or []
        if sel:
            cls.saved_slots[slot] = sel
            return len(sel)
        return 0

    @classmethod
    def load(cls, slot):
        if cls.saved_slots[slot]:
            valid = [s for s in cls.saved_slots[slot] if cmds.objExists(s.split(".")[0])]
            if valid:
                cmds.select(valid, replace=True)
                return True
        return False

    @classmethod
    def shortest_path_select(cls, use_uv=False):
        return pr_shortest_path_select(use_uv=use_uv)


