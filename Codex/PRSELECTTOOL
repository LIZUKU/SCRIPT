    def _connect(self):
        for _txt, (btn, vec) in self.dir_btns.items():
            btn.clicked.connect(lambda checked=False, v=vec: self._set_dir(v))
        self.cam_btn.clicked.connect(self._use_camera)
        self.angle_slider.valueChanged.connect(self.angle_spin.setValue)
        self.angle_spin.valueChanged.connect(self.angle_slider.setValue)
        self.angle_slider.valueChanged.connect(self._on_angle_change)
        self.angle_slider.sliderPressed.connect(self._capture_angle_scope_seed)
        self.angle_slider.sliderReleased.connect(self._clear_angle_scope_seed)
        self.angle_spin.editingFinished.connect(self._clear_angle_scope_seed)
        self.face_btn.clicked.connect(self._use_face)
        self.live_chk.stateChanged.connect(
            lambda s: setattr(self, "_live", s == QtCore.Qt.Checked))
        self.sel_angle_btn.clicked.connect(self._select_angle)
        self.both_chk.stateChanged.connect(lambda s: self._trigger_live_if_needed())
        self.plane_chk.stateChanged.connect(lambda s: self._trigger_live_if_needed())
        self.plane_tol.valueChanged.connect(lambda v: self._trigger_live_if_needed())

        self.inner_btn.clicked.connect(PR_SelectInnerFaces.run)
        self.contiguous_btn.clicked.connect(lambda: PR_SelectTools.select_contiguous_by_angle(60))
        self.similar_btn.clicked.connect(lambda: self._run_identical_mesh_search())
        self.similar_btn.customContextMenuRequested.connect(self._show_similar_context_menu)
        self.shortest_btn.clicked.connect(lambda: PR_SelectTools.shortest_path_select())
        self.ngon_btn.clicked.connect(PR_SelectTools.select_ngons)
        self.tri_btn.clicked.connect(PR_SelectTools.select_tris)

        for n, btn in self.skip_btns.items():
            btn.clicked.connect(lambda checked=False, val=n: self._set_skip(val))
        self.skip_spin.valueChanged.connect(lambda v: setattr(self, "_skip", v))
        self.loop_btn.clicked.connect(lambda: self._set_mode(1))
        self.ring_btn.clicked.connect(lambda: self._set_mode(2))
        self.both_btn.clicked.connect(lambda: self._set_mode(3))
        self.edge_sel_btn.clicked.connect(self._select_pattern)

        self.hard_edges_btn.clicked.connect(self._select_all_hard_edges)
        self.smooth_hard_btn.clicked.connect(self._select_smoothing_hard_edges)
        self.border_edges_btn.clicked.connect(self._select_border_edges)
        self.min_slider.valueChanged.connect(self.min_spin.setValue)
        self.min_spin.valueChanged.connect(self.min_slider.setValue)
        self.max_slider.valueChanged.connect(self.max_spin.setValue)
        self.max_spin.valueChanged.connect(self.max_slider.setValue)
        self.min_slider.sliderPressed.connect(self._capture_hard_scope_seed)
        self.max_slider.sliderPressed.connect(self._capture_hard_scope_seed)
        self.min_slider.sliderReleased.connect(self._clear_hard_scope_seed)
        self.max_slider.sliderReleased.connect(self._clear_hard_scope_seed)
        self.min_spin.editingFinished.connect(self._clear_hard_scope_seed)
        self.max_spin.editingFinished.connect(self._clear_hard_scope_seed)
