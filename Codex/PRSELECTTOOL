# SELECT BY ANGLE
# =============================================================================
class PR_SelectByAngle:
    _cached_mesh = None

    @classmethod
    def run(cls, angle, direction, both=False, plane_ref=None, plane_tol=0.001, scope_selection=None):
        mesh = pr_get_mesh_from_selection()
        if not mesh:
            if cls._cached_mesh and cmds.objExists(cls._cached_mesh):
                mesh = cls._cached_mesh
            else:
                return 0

        cls._cached_mesh = mesh
        pr_ensure_face_component_mode()

        ref    = list(direction)
        length = math.sqrt(sum(v**2 for v in ref))
        if length < 1e-8:
            cmds.select(clear=True)
            return 0
        ref = [v/length for v in ref]

        cos_thresh = math.cos(math.radians(angle))
        faces      = []

        use_plane = False
        p0 = pn = None
        if plane_ref and isinstance(plane_ref, (tuple, list)) and len(plane_ref) == 2:
            p0, pn = plane_ref
            if p0 and pn:
                pnl = math.sqrt(pn[0]**2 + pn[1]**2 + pn[2]**2)
                if pnl > 1e-8 and plane_tol is not None and plane_tol > 0.0:
                    pn = [pn[0]/pnl, pn[1]/pnl, pn[2]/pnl]
                    use_plane = True

        dag, fn = pr_get_dagpath_and_fnmesh(mesh)
        scope_face_indices = None
        if scope_selection is not None:
            scope_face_indices = []
            for face_comp in scope_selection:
                idx = pr_parse_face_index(face_comp)
                if idx is not None:
                    scope_face_indices.append(idx)
            scope_face_indices = sorted(set(scope_face_indices))

        if fn:
            face_indices = scope_face_indices if scope_face_indices is not None else range(fn.numPolygons)
            for i in face_indices:
                n  = fn.getPolygonNormal(i, om2.MSpace.kWorld)
                nl = n.length()
                if nl < 1e-8:
                    continue
                n    = n / nl
                dotv = (n.x*ref[0]) + (n.y*ref[1]) + (n.z*ref[2])
                if both:
                    dotv = abs(dotv)
                if dotv >= cos_thresh:
                    if use_plane:
                        vids   = fn.getPolygonVertices(i)
                        max_d  = 0.0
                        for vid in vids:
                            pt = fn.getPoint(vid, om2.MSpace.kWorld)
                            dx = pt.x - p0[0]
                            dy = pt.y - p0[1]
                            dz = pt.z - p0[2]
                            d  = abs((dx*pn[0]) + (dy*pn[1]) + (dz*pn[2]))
                            if d > max_d:
                                max_d = d
                                if max_d > plane_tol:
                                    break
                        if max_d > plane_tol:
                            continue
                    faces.append("{}.f[{}]".format(mesh, i))
            cmds.select(faces if faces else [], replace=True)
            pr_force_selection_faces_only()
            return len(cmds.ls(sl=True, fl=True) or [])

        face_indices = scope_face_indices if scope_face_indices is not None else range(cmds.polyEvaluate(mesh, face=True))
        for i in face_indices:
            face = "{}.f[{}]".format(mesh, i)
            info = cmds.polyInfo(face, faceNormals=True)
            if not info:
                continue
            p = info[0].split()
            n = [float(p[2]), float(p[3]), float(p[4])]
            nl = math.sqrt(sum(v**2 for v in n))
            if nl < 1e-8:
                continue
            n    = [v/nl for v in n]
            dotv = sum(n[j]*ref[j] for j in range(3))
            if both:
                dotv = abs(dotv)
            if dotv >= cos_thresh:
                faces.append(face)

        cmds.select(faces if faces else [], replace=True)
        pr_force_selection_faces_only()
        return len(cmds.ls(sl=True, fl=True) or [])

    @staticmethod
    def get_face_normal_and_plane_ref():
        sel = cmds.ls(sl=True, fl=True) or []
        face_comp = None
        for item in sel:
            if ".f[" in item:
                face_comp = item
                break
        if not face_comp:
            return None, None

        mesh = face_comp.split(".")[0]
        fi   = pr_parse_face_index(face_comp)
        if fi is None:
            return None, None

        dag, fn = pr_get_dagpath_and_fnmesh(mesh)
        if fn:
            n  = fn.getPolygonNormal(fi, om2.MSpace.kWorld)
            nl = n.length()
            if nl < 1e-8:
                return None, None
            n      = n / nl
            normal = [n.x, n.y, n.z]
            vids   = fn.getPolygonVertices(fi)
            if not vids:
                return normal, (None, None)
            sx = sy = sz = 0.0
            for vid in vids:
                pt = fn.getPoint(vid, om2.MSpace.kWorld)
                sx += pt.x; sy += pt.y; sz += pt.z
            inv = 1.0 / float(len(vids))
            p0  = [sx*inv, sy*inv, sz*inv]
            return normal, (p0, normal)

        info = cmds.polyInfo(face_comp, faceNormals=True)
        if info:
            p  = info[0].split()
            n  = [float(p[2]), float(p[3]), float(p[4])]
            nl = math.sqrt(sum(v**2 for v in n))
            if nl > 1e-8:
                n = [v/nl for v in n]
            return n, (None, None)
        return None, None


